# --- LLM provider ---------------------------------------------------------
# "anthropic" (Claude API, needs credits, default), "openrouter" (fallback,
# no Anthropic credits needed), or "ollama" (free, local)
LLM_PROVIDER=anthropic
OLLAMA_MODEL=llama3.1
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- OpenRouter fallback (used when LLM_PROVIDER=openrouter) ----------------
# Key from https://openrouter.ai/keys. FALLBACK_MODEL is any tool-calling
# capable OpenRouter model id (free ones work, but tool-calling is shakier).
OPENROUTER_API_KEY=sk-or-your-key-here
FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Supabase (always required for live mode) ------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Mock mode --------------------------------------------------------------
# true = no API key needed; the backend simulates a full booking so the UI is
# demoable. Set to false (or remove) to use the real agent.
USE_MOCK_AGENT=false

# --- Auth (signup / login / JWT sessions) -----------------------------------
# Signing secret for session tokens. If unset, the backend falls back to an
# insecure hardcoded dev value and prints a warning -- always set this in
# production.
JWT_SECRET=change-me-to-a-long-random-string

# --- Email confirmations (Resend) -------------------------------------------
# Get a key at https://resend.com/api-keys. FROM_EMAIL must be on a domain you
# verified in Resend (or use onboarding@resend.dev for testing).
RESEND_API_KEY=re_your-key-here
FROM_EMAIL=QueueZero <bookings@yourdomain.com>

# Demo fallback recipient: used when the booking form has no email field value.
PATIENT_EMAIL=patient@example.com

# Demo override: when set, ALL confirmation emails go here regardless of what
# the booking form sends. Needed because Resend's sandbox sender
# (onboarding@resend.dev) only delivers to the account owner's verified
# address -- set this to that address during the demo.
# DEMO_EMAIL_OVERRIDE=you@example.com

# --- Frontend (queuezero-ui/.env, not this file) -----------------------------
# VITE_API_URL=http://localhost:8000
# VITE_SUPABASE_URL=https://your-project.supabase.co   # same as SUPABASE_URL above
# VITE_SUPABASE_ANON_KEY=your-anon-key                 # "anon public" key from Supabase dashboard → Settings → API
